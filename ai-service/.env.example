# ════════════════════════════════════════════════════════════
#  DataPulse — AI Service Environment Variables (ÖRNEK)
#  .env dosyasını kopyalayıp kendi değerlerini gir:
#    cp .env.example .env
# ════════════════════════════════════════════════════════════

# Gemini API anahtarı (zorunlu)
GEMINI_API_KEY=AIzaSyB1MXCLdU3b70uyB1-LPEL9E7RTRXeNJMM

# Veritabanı bağlantısı (zorunlu — varsayılan yok, boş bırakılırsa servis başlamaz)
DATABASE_URL=mysql+pymysql://root:1234@localhost:3306/ecommerce_db
# DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/ecommerce_db

# CORS — Spring Boot backend origin(ları), virgülle ayrılır
ALLOWED_ORIGINS=http://localhost:8080

# İç servis güvenlik anahtarı — Spring Boot ile paylaşılan gizli anahtar
# Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SERVICE_SECRET=change_this_to_a_strong_random_secret
