# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Database connection (matches Spring Boot backend)
# For MySQL (default):
DATABASE_URL=mysql+pymysql://root:1234@localhost:3306/ecommerce_db
# For PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ecommerce_db

# Service port
PORT=8000
